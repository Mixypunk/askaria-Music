<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/widget_bg"
    android:padding="12dp">

    <!-- Pochette album -->
    <ImageView
        android:id="@+id/widget_artwork"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:scaleType="centerCrop"
        android:src="@mipmap/ic_launcher"/>

    <!-- Titre + Artiste -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Askaria"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/widget_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aucun titre"
            android:textColor="#B3B3B3"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

    <!-- Bouton Précédent -->
    <ImageButton
        android:id="@+id/widget_prev"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_widget_prev"
        android:contentDescription="Précédent"/>

    <!-- Bouton Play/Pause -->
    <ImageButton
        android:id="@+id/widget_play"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/widget_play_bg"
        android:src="@drawable/ic_widget_play"
        android:contentDescription="Lecture"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"/>

    <!-- Bouton Suivant -->
    <ImageButton
        android:id="@+id/widget_next"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_widget_next"
        android:contentDescription="Suivant"/>

</LinearLayout>
